# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database Local (Docker)
DATABASE_URL=
DATABASE_PASSWORD=

# Resend — dominio verificado: neonshop.shop
RESEND_API_KEY=
# Remitente oficial (debe estar verificado en Resend)
RESEND_FROM_EMAIL=no-reply@neonshop.shop

# URL pública del sitio (emails, reset password, sitemap)
NEXT_PUBLIC_SITE_URL=https://www.neonshop.shop

# Admin: emails separados por coma reciben rol admin al registrarse
ADMIN_EMAILS=

# API URL (opcional en servidor)
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000

# WhatsApp fallback solo desarrollo si site_settings.whatsapp_number está vacío
NEXT_PUBLIC_WHATSAPP_NUMBER=

